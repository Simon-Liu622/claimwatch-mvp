# Base URL used in canonical URLs, sitemap, RSS, llms.txt, and JSON APIs.
SITE_URL=https://example.com

# Optional. Use this for automated Google Trends Trending Now ingestion.
# Without it, the crawler falls back to TRENDING_CSV_PATH or Google Trends RSS.
SERPAPI_KEY=

# Optional. Point at a Google Trends CSV export, like:
# /Users/simon/Downloads/trending_US_7d_20260507-1415.csv
TRENDING_CSV_PATH=

# Optional. Crawler region for trends fallback/API.
TRENDS_GEO=US

# Optional. NHTSA does not provide a simple latest-all-recalls endpoint in the
# same shape as FDA/CPSC, so the MVP polls configured vehicle targets.
# Format: make|model|year;make|model|year
NHTSA_TARGETS=tesla|model 3|2024;ford|f-150|2024;toyota|camry|2024;honda|accord|2024;chevrolet|silverado 1500|2024;hyundai|tucson|2024;kia|telluride|2024;jeep|wrangler|2024

# Optional. Fetch timeout in milliseconds.
FETCH_TIMEOUT_MS=12000
